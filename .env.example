# Nenhuma credencial e obrigatoria para o MVP: todos os dados sao lidos de
# arquivos locais oficiais ja baixados (ver config/data_sources.yaml).
# Variaveis abaixo sao opcionais, usadas apenas se o download automatico
# TSE/IBGE precisar ser acionado (arquivos ainda nao presentes localmente).

# Diretorio raiz onde os arquivos brutos do TSE/IBGE estao ou serao salvos
SIE_DATA_DIR=data/raw

# Timeout (segundos) para downloads automaticos do TSE/IBGE
SIE_DOWNLOAD_TIMEOUT=120
